# Django secret key — generate a strong random value for production
# python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=your-secret-key-here

# Set to False in production
DEBUG=True

# Comma-separated list of allowed hosts, e.g. localhost,127.0.0.1,yourdomain.com
ALLOWED_HOSTS=localhost,127.0.0.1

# ---------------------------------------------------------------------------
# Database (PostgreSQL for production)
# ---------------------------------------------------------------------------
DB_ENGINE=django.db.backends.postgresql
DB_NAME=iles_db
DB_USER=postgres
DB_PASSWORD=your-db-password
DB_HOST=localhost
DB_PORT=5432

# ---------------------------------------------------------------------------
# CORS — comma-separated list of allowed frontend origins
# ---------------------------------------------------------------------------
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

# Frontend reset-password page. The backend will email links like:
# http://localhost:5173/reset-password?uid=<uid>&token=<token>
FRONTEND_URL=http://localhost:5173
FRONTEND_PASSWORD_RESET_PATH=/reset-password

# ---------------------------------------------------------------------------
# Email Configuration
# ---------------------------------------------------------------------------
# Local development can use console email by leaving EMAIL_HOST_USER and
# EMAIL_HOST_PASSWORD as placeholders. To deliver inbox email, use real SMTP
# credentials. For Gmail, EMAIL_HOST_PASSWORD must be an app password.
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
EMAIL_USE_TLS=True
EMAIL_USE_SSL=False
EMAIL_TIMEOUT=20
DEFAULT_FROM_EMAIL=ILES System <your-email@gmail.com>
